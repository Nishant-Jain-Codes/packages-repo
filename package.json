{
  "name": "@aditya-sharma-salescode/monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter \"!form-builder-verify-vite\" build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "verify:form-builder-vite": "pnpm run build && pnpm --filter form-builder-verify-vite build"
  }
}

